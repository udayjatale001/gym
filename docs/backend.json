
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Core physical and goal data for the user.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "age": { "type": "number" },
        "currentWeight": { "type": "number" },
        "targetWeight": { "type": "number" },
        "height": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "activityLevel": { "type": "string", "enum": ["sedentary", "lightly active", "moderately active", "very active", "extremely active"] },
        "goal": { "type": "string" },
        "workoutStartDate": { "type": "string", "format": "date", "description": "The date the 3-day PPL cycle started." }
      },
      "required": ["displayName", "currentWeight", "targetWeight"]
    },
    "WeightLog": {
      "title": "Weight Log",
      "description": "Daily weight tracking entry.",
      "type": "object",
      "properties": {
        "weight": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["weight", "date"]
    },
    "WorkoutLog": {
      "title": "Workout Log",
      "description": "A single workout session history stored as free-form text.",
      "type": "object",
      "properties": {
        "workoutType": { "type": "string" },
        "day": { "type": "number" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["workoutType", "day", "description"]
    },
    "WorkoutSplit": {
      "title": "Workout Split",
      "description": "A custom user-defined workout split category.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "focus": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "MealLog": {
      "title": "Meal Log",
      "description": "Detailed meal entry.",
      "type": "object",
      "properties": {
        "mealType": { "type": "string", "enum": ["Breakfast", "Snacks", "Lunch", "Dinner"] },
        "mealName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["mealType", "mealName", "timestamp", "date"]
    },
    "ChecklistEntry": {
      "title": "Checklist Entry",
      "description": "A manual status for a specific day in a 30-day cycle.",
      "type": "object",
      "properties": {
        "day": { "type": "number" },
        "status": { "type": "string", "enum": ["taken", "skipped"] }
      },
      "required": ["day", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data."
    },
    "/users/{userId}/weightLogs/{logId}": {
      "schema": "WeightLog",
      "description": "Weight history for the user."
    },
    "/users/{userId}/workoutLogs/{logId}": {
      "schema": "WorkoutLog",
      "description": "Workout history for the user."
    },
    "/users/{userId}/workoutSplits/{splitId}": {
      "schema": "WorkoutSplit",
      "description": "Custom workout splits created by the user."
    },
    "/users/{userId}/mealLogs/{mealId}": {
      "schema": "MealLog",
      "description": "Detailed meal history."
    },
    "/users/{userId}/mealLogs/{mealId}/checklist/{dayId}": {
      "schema": "ChecklistEntry",
      "description": "30-day consistency data for a specific meal."
    }
  }
}
